<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<title>{{ title }}</title>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; max-width: 900px; margin: 40px auto; padding: 20px; color: #333; line-height: 1.6; }
  h1 { color: #e74c3c; border-bottom: 3px solid #e74c3c; padding-bottom: 10px; }
  h2 { color: #2c3e50; margin-top: 30px; }
  h3 { color: #34495e; }
  table { width: 100%; border-collapse: collapse; margin: 15px 0; }
  th, td { border: 1px solid #ddd; padding: 10px; text-align: left; }
  th { background: #f5f5f5; }
  .severity-critical { background: #ff4444; color: white; padding: 3px 8px; border-radius: 4px; }
  .severity-high { background: #ff8800; color: white; padding: 3px 8px; border-radius: 4px; }
  .severity-medium { background: #ffbb00; padding: 3px 8px; border-radius: 4px; }
  .severity-low { background: #8bc34a; padding: 3px 8px; border-radius: 4px; }
  .finding { background: #f9f9f9; border-left: 4px solid #e74c3c; padding: 15px; margin: 15px 0; }
  code { background: #f0f0f0; padding: 2px 6px; border-radius: 3px; font-size: 0.9em; }
  .footer { margin-top: 40px; color: #888; font-size: 0.8em; text-align: center; }
</style>
</head>
<body>
<h1>🔴 {{ title }}</h1>
<p><strong>Generated:</strong> {{ generated_at }}<br>
<strong>Target:</strong> {{ target }}<br>
<strong>Objective:</strong> {{ objective }}<br>
<strong>Operation ID:</strong> {{ operation_id }}<br>
<strong>Duration:</strong> {{ duration_seconds }}s</p>

<h2>Executive Summary</h2>
<p>{{ summary if summary else "AKATSUKI operation completed." }}</p>

{% if severity_counts %}
<table>
<tr><th>Severity</th><th>Count</th></tr>
{% for sev, count in severity_counts.items() %}
<tr><td><span class="severity-{{ sev|lower }}">{{ sev }}</span></td><td>{{ count }}</td></tr>
{% endfor %}
</table>
{% endif %}

<h2>Findings</h2>
{% for finding in findings %}
<div class="finding">
<h3>{{ loop.index }}. {{ finding.get('title', 'Finding ' ~ loop.index) }}</h3>
<p><strong>Phase:</strong> {{ finding.get('phase', 'N/A') }} &nbsp; <strong>Severity:</strong> <span class="severity-{{ finding.get('severity', 'medium')|lower }}">{{ finding.get('severity', 'N/A') }}</span></p>
<pre>{{ finding.get('description', '')[:500] }}</pre>
</div>
{% endfor %}

<h2>MITRE ATT&CK Coverage</h2>
<ul>
{% for technique in mitre_techniques %}
<li><code>{{ technique.id }}</code> — {{ technique.name }} ({{ technique.phase }})</li>
{% endfor %}
</ul>

<h2>Final Assessment</h2>
<p>{{ final_report[:2000] if final_report else "AKATSUKI operation completed." }}</p>

<div class="footer">Generated by AKATSUKI at {{ generated_at }}</div>
</body>
</html>